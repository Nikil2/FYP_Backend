### ==================================================
### WORKER REGISTRATION & PORTFOLIO API TESTS
### ==================================================

### Setup Variables
@baseUrl = http://localhost:3000
@workerId = worker-id-from-response
@portfolioId = portfolio-id-from-response
@serviceId1 = 1
@serviceId2 = 2

### ==================================================
### 1. GET SERVICES (For Worker Registration)
### ==================================================

### Get All Services (43 Total)
GET {{baseUrl}}/services
Content-Type: application/json

### Get Active Services Only
GET {{baseUrl}}/services/active
Content-Type: application/json

### Get Services List
GET {{baseUrl}}/services/list/all
Content-Type: application/json

### Get Service by ID
GET {{baseUrl}}/services/1
Content-Type: application/json

### ==================================================
### 2. WORKER REGISTRATION WITH SERVICES & PORTFOLIO
### ==================================================

### Register New Worker - Plumber (with services and portfolio images)
POST {{baseUrl}}/workers/register
Content-Type: application/json

{
  "phoneNumber": "+923001234567",
  "password": "SecurePass123!",
  "fullName": "Ali Ahmed Khan",
  "cnicNumber": "12345-6789012-3",
  "cnicFrontUrl": "https://example.com/cnic-front.jpg",
  "cnicBackUrl": "https://example.com/cnic-back.jpg",
  "homeAddress": "123 Main Street, Karachi",
  "homeLat": 24.8615,
  "homeLng": 67.0099,
  "experienceYears": 5,
  "visitingCharges": 500,
  "bio": "Professional plumber with 5 years of experience",
  "serviceIds": [7, 8, 9, 10, 11, 12],
  "portfolioImages": [
    {
      "imageUrl": "https://example.com/portfolio1.jpg",
      "description": "Bathroom renovation project"
    },
    {
      "imageUrl": "https://example.com/portfolio2.jpg",
      "description": "Kitchen pipe installation"
    },
    {
      "imageUrl": "https://example.com/portfolio3.jpg",
      "description": "Water leak repair"
    }
  ]
}

### Register Worker - Electrician Services
POST {{baseUrl}}/workers/register
Content-Type: application/json

{
  "phoneNumber": "+923009876543",
  "password": "SecurePass123!",
  "fullName": "Hassan Ali",
  "cnicNumber": "09876-5432109-8",
