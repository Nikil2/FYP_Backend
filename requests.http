### ==================================================
### WORKFLOW EXAMPLES
### ==================================================

### Example 1: Complete Worker Registration Flow
# Step 1: Fetch all services
GET {{baseUrl}}/services/active

# Step 2: Worker selects services (e.g., serviceIds: [7,8,9,10,11,12] for Plumber)
# Step 3: Register with selected services and portfolio
POST {{baseUrl}}/workers/register

# Step 4: Get worker details (includes services and portfolio)
GET {{baseUrl}}/workers/worker-id

# Step 5: Add more portfolio images later
POST {{baseUrl}}/workers/{{workerId}}/portfolio

### Example 2: List Services for Frontend
# Frontend calls this endpoint to get all available services
GET {{baseUrl}}/services/list/all

# Response contains all 43 services with:
# - id: Unique service ID
# - name: Service name
# - iconUrl: Icon/emoji for display
# - isActive: Whether service is available

### ==================================================
### RUNNING THE SEED
### ==================================================

# Before testing, run the seed script:
# npx prisma db seed

# This will create all 43 services in the database

### ==================================================
### NOTES & TIPS
### ==================================================

# All 43 services are seeded into database
# Service IDs auto-increment from 1
# Use GET /services or /services/active to fetch dynamically
# Icons stored as emoji in database (optional but nice for UI)
# Services can be filtered by active status
# Workers select multiple services during signup
# Portfolio images stored separately per worker
# Each service can have multiple workers offering it
# Each worker can offer multiple services
